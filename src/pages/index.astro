---
// 1. 导入你的数据源
import rolesData from '../data/roles.json';

// 2. 提取所有不重复的国家列表（为了将来扩展多个国家做准备）
const countries = [...new Set(rolesData.map(item => item.country))];

// 3. 网站基础 SEO 描述
const siteTitle = "TalentScaleHQ | Nearshore Developer Cost & Salary Directory 2026";
const siteDescription = "Compare accurate employment costs, taxes, and EOR fees for hiring software developers across Latin America and Eastern Europe.";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{siteTitle}</title>
    <meta name="description" content={siteDescription} />
    <style>
      body { font-family: system-ui, sans-serif; line-height: 1.6; color: #333; max-width: 900px; margin: 0 auto; padding: 2rem; }
      h1 { font-size: 2.5rem; color: #0f172a; margin-bottom: 0.5rem; }
      .subtitle { font-size: 1.2rem; color: #64748b; margin-bottom: 3rem; border-bottom: 2px solid #eee; padding-bottom: 1rem; }
      .country-section { margin-bottom: 2.5rem; background: #f8fafc; padding: 1.5rem; border-radius: 8px; border: 1px solid #e2e8f0; }
      .country-title { color: #1e293b; font-size: 1.5rem; margin-top: 0; }
      .role-list { list-style: none; padding: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem; }
      .role-list li a { display: block; padding: 1rem; background: white; border: 1px solid #cbd5e1; border-radius: 6px; text-decoration: none; color: #2563eb; font-weight: 500; transition: box-shadow 0.2s; }
      .role-list li a:hover { box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1); text-decoration: underline; }
    </style>
  </head>
  <body>
    
    <header>
      <h1>Global Tech Talent Cost Directory</h1>
      <p class="subtitle">Skip the guesswork. Access verified 2026 employment costs, local taxes, and salary data for hiring remote engineering teams.</p>
    </header>

    <main>
      {countries.map(country => (
        <section class="country-section">
          <h2 class="country-title">Top Roles in {country}</h2>
          <ul class="role-list">
            {rolesData
              .filter(role => role.country === country)
              .map(role => (
                <li>
                  <a href={`/${role.slug}`}>
                    Hire {role.level} {role.role} in {country} &rarr;
                  </a>
                </li>
              ))}
          </ul>
        </section>
      ))}
    </main>

  </body>
</html>